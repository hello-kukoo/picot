.npm-cache/
.worktrees/
# npm lock file (this project uses bun exclusively; see AGENTS.md)
package-lock.json
.DS_Store

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Pi extension bundles (produced by scripts/build-extensions.js)
extensions/dist/

