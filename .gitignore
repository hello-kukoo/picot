public/fonts/terminal/

# Generated CJK font assets (produced by scripts/fetch-cjk-font.js)
public/fonts/cjk/

# Pi session exports
pi-session-*.html
# Local build artifacts (produced by scripts/build.sh)
*.dmg
*.zip
# husky internal scripts (managed by `bun run prepare`)
.husky/_/

# Superpowers plans
docs/superpowers/plans

# plannator plans
plans/

# Frontend vendor bundles (produced by scripts/build-frontend.js)
public/vendor/
