{
  "name": "tau-mirror",
  "version": "1.0.7",
  "description": "Web UI that mirrors your Pi terminal session in the browser",
  "keywords": [
    "pi",
    "pi-package",
    "coding-agent",
    "web-ui",
    "mirror"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deflating/tau.git"
  },
  "pi": {
    "extensions": [
      "./extensions/mirror-server.ts"
    ],
    "image": "https://raw.githubusercontent.com/deflating/tau/main/docs/images/dark.png"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "test": "vitest run && node scripts/check-tauri-permissions.js",
    "test:watch": "vitest",
    "check:permissions": "node scripts/check-tauri-permissions.js",
    "check:rust": "bash scripts/check-rust.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "qrcode": "^1.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
